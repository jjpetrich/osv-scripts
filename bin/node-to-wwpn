#!/usr/bin/env bash
# node-to-wwpn
# List Fibre Channel WWPNs for OpenShift worker nodes.
# - By default queries all non-control/master nodes in parallel.
# - If a node name is provided, only that node is queried.
# - --raw prints node:wwpn in colon-separated byte format.
# - Progress summary printed to stderr while querying many nodes.
set -euo pipefail

progname=$(basename "$0")

# Defaults
PARALLEL=25
RAW_MODE=0
NODE_ARG=""
DEBUG_MODE=0
RETRIES=2        # number of retries (in addition to the initial attempt)
BACKOFF_BASE=2   # backoff base seconds (exponential: 2,4,...)
PROGRESS_INTERVAL=2  # seconds between progress updates

usage() {
  cat <<USAGE
Usage:
  $progname [<node-name>] [--raw] [--parallel N] [--debug]

If <node-name> is omitted the script will query all non-control/master nodes in parallel.
--raw      Print node:wwpn in colon-separated byte format.
--parallel N  Concurrency when querying all nodes (default: ${PARALLEL}).
--debug    Print extra debug messages (to stderr) while nodes are being queried.

Examples:
  $progname
  $progname --raw
  $progname --parallel 20 --debug
  $progname worker-02.example.com --raw
USAGE
  exit 1
}

# Parse args (simple)
while (( $# )); do
  case "$1" in
    -h|--help) usage ;;
    --raw) RAW_MODE=1; shift ;;
    --debug) DEBUG_MODE=1; shift ;;
    --parallel)
      shift
      if [[ $# -eq 0 ]]; then echo "--parallel requires an argument" >&2; usage; fi
      PARALLEL="$1"
      if ! [[ "$PARALLEL" =~ ^[0-9]+$ ]]; then echo "Invalid parallel value: $PARALLEL" >&2; exit 2; fi
      shift
      ;;
    --parallel=*)
      PARALLEL="${1#*=}"
      if ! [[ "$PARALLEL" =~ ^[0-9]+$ ]]; then echo "Invalid parallel value: $PARALLEL" >&2; exit 2; fi
      shift
      ;;
    -*)
      echo "Unknown option: $1" >&2; usage ;;
    *)
      if [[ -z "$NODE_ARG" ]]; then
        NODE_ARG="$1"
      else
        echo "Unknown argument: $1" >&2; usage
      fi
      shift
      ;;
  esac
done

timestamp() { date "+%Y-%m-%d %H:%M:%S"; }

debug() {
  if [[ "$DEBUG_MODE" -eq 1 ]]; then
    echo "$(timestamp) [DEBUG] $*" >&2
  fi
}

progress() {
  # print a short progress summary (always on stderr)
  echo "$(timestamp) [PROGRESS] $*" >&2
}

# Remote script executed inside chroot /host on each node.
# It prints tab-separated fields:
# HOST<TAB>WWPN(port)<TAB>WWNN(node)<TAB>STATE<TAB>SPEED<TAB>PCI<TAB>DRIVER<TAB>SYMBOLIC_NAME
read -r -d '' REMOTE_SCRIPT <<'EOF' || true
#!/usr/bin/env bash
OC_NODE_NAME="${OC_NODE_NAME:-unknown-node}"

# Helper: strip leading 0x or 0X and normalize to lowercase
strip_0x() {
  local s="$1"
  s="${s#0x}"
  s="${s#0X}"
  printf '%s' "${s,,}"
}

for h in /sys/class/fc_host/host*; do
  [ -d "$h" ] || continue

  raw_port=$(cat "$h/port_name" 2>/dev/null || echo "")
  raw_node=$(cat "$h/node_name" 2>/dev/null || echo "")
  port_state=$(cat "$h/port_state" 2>/dev/null || echo "")
  port_speed=$(cat "$h/port_speed" 2>/dev/null || echo "")

  # strip 0x prefix if present and lowercase
  port_name=$(strip_0x "$raw_port")
  node_name=$(strip_0x "$raw_node")

  devpath=$(readlink -f "$h/device" 2>/dev/null || true)
  pci=""
  driver=""
  if [[ -n "$devpath" ]]; then
    candidate="$devpath"
    while [[ "$candidate" != "/" && -z "$pci" ]]; do
      base=$(basename "$candidate")
      if [[ "$base" =~ ^[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]$ ]]; then
        pci="$base"
        break
      fi
      candidate=$(dirname "$candidate")
    done

    if [[ -e "$devpath/driver" ]]; then
      driver=$(basename "$(readlink -f "$devpath/driver")" 2>/dev/null || true)
    fi
  fi

  symbolic=""
  if [[ -r "$h/symbolic_name" ]]; then
    symbolic=$(cat "$h/symbolic_name" 2>/dev/null || echo "")
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "${OC_NODE_NAME}" \
    "${port_name}" \
    "${node_name}" \
    "${port_state}" \
    "${port_speed}" \
    "${pci}" \
    "${driver}" \
    "${symbolic}"
done
EOF

# Format WWPN into colon-separated bytes e.g. aa:bb:cc:dd:ee:ff:00:11
format_colon() {
  local w="$1"
  w="${w,,}"
  w="${w//[^0-9a-f]/}"
  if (( ${#w} % 2 == 1 )); then w="0${w}"; fi
  local out=""; local i=0
  while (( i < ${#w} )); do
    if [[ -n "$out" ]]; then out="${out}:"; fi
    out="${out}${w:i:2}"
    i=$((i+2))
  done
  printf '%s' "$out"
}

# A single attempt to query a node (no retries). Returns 0 on success, non-zero on failure.
_oc_debug_once() {
  local node="$1"
  local outpath="$2"
  # capture stdout/stderr separately
  if oc debug -T "node/${node}" --quiet -- bash -c \
    "chroot /host /bin/bash -s <<'INNERSH'
export OC_NODE_NAME='${node}'
${REMOTE_SCRIPT}
INNERSH" >"${outpath}" 2> "${outpath}.err"; then
    return 0
  else
    return 1
  fi
}

# Query node with retries and exponential backoff.
# Writes successful stdout to outpath, or leaves outpath.failed and .err.tail on failure.
query_node_with_retries() {
  local node="$1"; local outpath="$2"
  local attempt=0
  local max_attempts=$((RETRIES + 1))
  while (( attempt < max_attempts )); do
    attempt=$((attempt+1))
    debug "Node ${node}: attempt ${attempt}/${max_attempts}"
    if _oc_debug_once "$node" "$outpath"; then
      debug "Node ${node}: success on attempt ${attempt}"
      return 0
    fi
    # failed
    debug "Node ${node}: failure on attempt ${attempt}"
    if (( attempt < max_attempts )); then
      sleep_secs=$(( BACKOFF_BASE * (2 ** (attempt-1)) ))
      debug "Node ${node}: sleeping ${sleep_secs}s before retry"
      sleep "$sleep_secs"
    fi
  done

  # after attempts exhausted: mark failed and preserve trimmed stderr
  echo "error: unable to create debug pod for '${node}' (after ${max_attempts} attempts)" > "${outpath}.failed.msg"
  if [[ -s "${outpath}.err" ]]; then
    head -n 200 "${outpath}.err" > "${outpath}.err.tail" || true
    rm -f "${outpath}.err"
  fi
  return 1
}

# Get node list:
get_target_nodes() {
  if [[ -n "$NODE_ARG" ]]; then
    printf '%s\n' "$NODE_ARG"
    return 0
  fi

  nodes=$(oc get nodes --selector='node-role.kubernetes.io/worker' -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null || true)
  if [[ -n "$nodes" ]]; then printf '%s\n' "$nodes"; return 0; fi

  nodes=$(oc get nodes --selector='!node-role.kubernetes.io/master,!node-role.kubernetes.io/control-plane' -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null || true)
  if [[ -n "$nodes" ]]; then printf '%s\n' "$nodes"; return 0; fi

  oc get nodes -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}'
}

# SHORT-CIRCUIT: single node & RAW
if [[ -n "$NODE_ARG" && "$RAW_MODE" -eq 1 ]]; then
  debug "Querying single node (raw): $NODE_ARG"
  tmpf=$(mktemp)
  if query_node_with_retries "$NODE_ARG" "$tmpf"; then
    while IFS=$'\t' read -r host wwpn rest; do
      [[ -z "$wwpn" ]] && continue
      fmt=$(format_colon "$wwpn")
      printf '%s:%s\n' "$host" "$fmt"
    done < "$tmpf"
    rm -f "$tmpf" "${tmpf}.err" "${tmpf}.err.tail" "${tmpf}.failed.msg"
    exit 0
  else
    # print failure info
    if [[ -f "${tmpf}.failed.msg" ]]; then
      cat "${tmpf}.failed.msg" >&2
    fi
    if [[ -f "${tmpf}.err.tail" ]]; then
      echo "oc debug stderr (trimmed):" >&2
      sed -n '1,200p' "${tmpf}.err.tail" >&2
    fi
    rm -f "$tmpf" "${tmpf}.err" "${tmpf}.err.tail" "${tmpf}.failed.msg"
    exit 1
  fi
fi

# SINGLE node & NOT RAW: header + aligned output
if [[ -n "$NODE_ARG" && "$RAW_MODE" -eq 0 ]]; then
  debug "Querying single node: $NODE_ARG"
  tmpf=$(mktemp)
  if query_node_with_retries "$NODE_ARG" "$tmpf"; then
    {
      printf 'HOST\tWWPN(port)\tWWNN(node)\tSTATE\tSPEED\tPCI\tDRIVER\tSYMBOLIC_NAME\n'
      cat "$tmpf"
    } | column -t -s $'\t'
    rm -f "$tmpf" "${tmpf}.err" "${tmpf}.err.tail" "${tmpf}.failed.msg"
    exit 0
  else
    if [[ -f "${tmpf}.failed.msg" ]]; then cat "${tmpf}.failed.msg" >&2; fi
    if [[ -f "${tmpf}.err.tail" ]]; then echo "oc debug stderr (trimmed):" >&2; sed -n '1,200p' "${tmpf}.err.tail" >&2; fi
    rm -f "$tmpf" "${tmpf}.err" "${tmpf}.err.tail" "${tmpf}.failed.msg"
    exit 1
  fi
fi

# MULTI-node path (parallel)
nodes_list=()
while IFS= read -r n; do
  [[ -z "$n" ]] && continue
  nodes_list+=("$n")
done < <(get_target_nodes)

if [[ ${#nodes_list[@]} -eq 0 ]]; then
  echo "No target nodes found." >&2; exit 2
fi

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# run_and_save invoked in background for each node
run_and_save() {
  local nod="$1"; local outf="$2"
  progress "Starting ${nod}"
  if query_node_with_retries "$nod" "$outf"; then
    # success: mark done
    touch "${outf}.done"
    progress "Completed ${nod}"
  else
    touch "${outf}.failed"
    progress "Failed ${nod}"
  fi
}

# Start monitor that prints Progress: X/Y every PROGRESS_INTERVAL seconds.
monitor_pid=""
start_monitor() {
  local total="$1"
  (
    while :; do
      completed=$(find "$TMPDIR" -name '*.done' 2>/dev/null | wc -l)
      failed=$(find "$TMPDIR" -name '*.failed' 2>/dev/null | wc -l)
      inprogress=$(( total - completed - failed ))
      progress "Progress: ${completed}/${total} completed, ${failed} failed, ${inprogress} in-progress"
      # exit when all nodes accounted for
      if (( completed + failed >= total )); then
        break
      fi
      sleep "$PROGRESS_INTERVAL"
    done
  ) &
  monitor_pid=$!
}

# Launch background jobs up to PARALLEL
start_monitor "${#nodes_list[@]}"

for n in "${nodes_list[@]}"; do
  outf="${TMPDIR}/${n}.out"
  # throttle: wait while there are >= PARALLEL running jobs
  while (( $(jobs -rp | wc -l) >= PARALLEL )); do
    sleep 0.05
  done
  run_and_save "$n" "$outf" &
done

# Wait for jobs
wait

# Ensure monitor finished
if [[ -n "$monitor_pid" ]]; then
  wait "$monitor_pid" 2>/dev/null || true
fi

# Final output
if [[ "$RAW_MODE" -eq 1 ]]; then
  for n in "${nodes_list[@]}"; do
    outf="${TMPDIR}/${n}.out"
    if [[ -f "${outf}.failed" ]]; then
      echo "error: failed to query ${n}" >&2
      if [[ -f "${outf}.failed.msg" ]]; then sed -n '1,200p' "${outf}.failed.msg" >&2; fi
      if [[ -f "${outf}.err.tail" ]]; then echo "oc debug stderr for ${n} (trimmed):" >&2; sed -n '1,200p' "${outf}.err.tail" >&2; fi
      continue
    fi
    if [[ -f "$outf" ]]; then
      while IFS=$'\t' read -r host wwpn rest; do
        [[ -z "$wwpn" ]] && continue
        fmt=$(format_colon "$wwpn")
        printf '%s:%s\n' "$host" "$fmt"
      done < "$outf"
    fi
  done
  exit 0
fi

# Non-raw: print header and aligned table combining all successful outputs.
{
  printf 'HOST\tWWPN(port)\tWWNN(node)\tSTATE\tSPEED\tPCI\tDRIVER\tSYMBOLIC_NAME\n'
  for n in "${nodes_list[@]}"; do
    outf="${TMPDIR}/${n}.out"
    if [[ -f "${outf}.failed" ]]; then
      echo "## ERROR: failed to query ${n}" >&2
      if [[ -f "${outf}.failed.msg" ]]; then sed -n '1,200p' "${outf}.failed.msg" >&2; fi
      if [[ -f "${outf}.err.tail" ]]; then echo "## oc debug stderr for ${n} (trimmed):" >&2; sed -n '1,200p' "${outf}.err.tail" >&2; fi
      continue
    fi
    if [[ -f "$outf" ]]; then
      cat "$outf"
    fi
  done
} | column -t -s $'\t'

# Final summary
completed=$(find "$TMPDIR" -name '*.done' 2>/dev/null | wc -l || true)
failed=$(find "$TMPDIR" -name '*.failed' 2>/dev/null | wc -l || true)
progress "Finished: ${completed} succeeded, ${failed} failed."

exit 0
