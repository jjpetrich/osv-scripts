#!/usr/bin/env bash
# node-to-wwpn
# Show Fibre Channel WWPNs for OpenShift nodes.
# If a node name is given, show only that node. If no node is given, list all nodes.
# Usage:
#   node-to-wwpn <node-name>
#   node-to-wwpn             # list all nodes
#   node-to-wwpn <node-name> --raw   # only WWPN values (no header / simpler output)

set -euo pipefail

progname=$(basename "$0")

usage() {
  cat <<USAGE
Usage:
  $progname [<node-name>] [--raw]

If <node-name> is omitted, the script will iterate all OpenShift nodes.
--raw prints only WWPNs (one per line) prefixed by node when multiple nodes are requested.

Examples:
  $progname worker-2.example.com
  $progname              # query all nodes
  $progname worker-2.example.com --raw
USAGE
  exit 1
}

RAW=""
NODE_ARG=""

# Basic arg parsing
while (( $# )); do
  case "$1" in
    -h|--help) usage ;;
    --raw) RAW="--raw"; shift ;;
    *) 
      if [[ -z "$NODE_ARG" ]]; then
        NODE_ARG="$1"
      else
        echo "Unknown argument: $1" >&2
        usage
      fi
      shift
      ;;
  esac
done

# Remote script to run inside chroot /host on the node.
# It will output rows with fields separated by tabs:
# HOST(oc node name) <TAB> WWPN(port_name) <TAB> WWNN(node_name) <TAB> STATE <TAB> SPEED <TAB> PCI <TAB> DRIVER <TAB> SYMBOLIC_NAME
read -r -d '' REMOTE_SCRIPT <<'EOF' || true
#!/usr/bin/env bash
# This runs on the node host filesystem (chroot /host)
# Expect environment variable: OC_NODE_NAME set by the wrapper (OpenShift node name)
OC_NODE_NAME="${OC_NODE_NAME:-unknown-node}"

# Find fc host directories
for h in /sys/class/fc_host/host*; do
  [ -d "$h" ] || continue

  # read attributes (silently tolerate missing)
  port_name=$(cat "$h/port_name" 2>/dev/null || echo "")
  node_name=$(cat "$h/node_name" 2>/dev/null || echo "")
  port_state=$(cat "$h/port_state" 2>/dev/null || echo "")
  port_speed=$(cat "$h/port_speed" 2>/dev/null || echo "")

  # driver and pci: walk from the fc_host to the underlying device
  # (readlink -f to follow symlinks safely)
  devpath=$(readlink -f "$h/device" 2>/dev/null || true)
  # attempt to locate PCI device by walking up
  pci=""
  driver=""
  if [[ -n "$devpath" ]]; then
    # find first ancestor containing a PCI address like 0000:00:17.0
    candidate="$devpath"
    while [[ "$candidate" != "/" && -z "$pci" ]]; do
      base=$(basename "$candidate")
      if [[ "$base" =~ ^[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]$ ]]; then
        pci="$base"
        break
      fi
      candidate=$(dirname "$candidate")
    done

    # driver name (if the device has a driver symlink)
    if [[ -e "$devpath/driver" ]]; then
      driver=$(basename "$(readlink -f "$devpath/driver")" 2>/dev/null || true)
    fi
  fi

  # symbolic name: try to read the port_name in colon format or from device attributes if present
  symbolic=""
  # Some drivers expose a 'symbolic_name' attribute; read if present
  if [[ -r "$h/symbolic_name" ]]; then
    symbolic=$(cat "$h/symbolic_name" 2>/dev/null || echo "")
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "${OC_NODE_NAME}" \
    "${port_name}" \
    "${node_name}" \
    "${port_state}" \
    "${port_speed}" \
    "${pci}" \
    "${driver}" \
    "${symbolic}"
done
EOF

# Function to query a single node and stream its output
query_node() {
  local node="$1"
  local raw_flag="$2"

  # Build oc debug command.
  # We'll export OC_NODE_NAME before executing the remote here-doc so the remote has the OpenShift node name.
  if [[ -n "$raw_flag" ]]; then
    # raw: set RAW_MODE=1 to possibly let remote behave differently (not needed here but kept for compatibility)
    oc debug "node/${node}" --quiet -- bash -c \
      "chroot /host /bin/bash -s <<'INNERSH'
export OC_NODE_NAME='${node}'
export RAW_MODE=1
${REMOTE_SCRIPT}
INNERSH"
  else
    oc debug "node/${node}" --quiet -- bash -c \
      "chroot /host /bin/bash -s <<'INNERSH'
export OC_NODE_NAME='${node}'
${REMOTE_SCRIPT}
INNERSH"
  fi
}

# If a single node specified, only query that node; otherwise loop all nodes
if [[ -n "${NODE_ARG}" ]]; then
  # Just one node
  if [[ -z "${RAW}" ]]; then
    # Print header
    printf 'HOST\tWWPN(port)\tWWNN(node)\tSTATE\tSPEED\tPCI\tDRIVER\tSYMBOLIC_NAME\n'
  fi
  query_node "${NODE_ARG}" "${RAW}"
  exit 0
fi

# No node specified: query all nodes
# Get the node list in a stable way
nodes=$(oc get nodes -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}')

if [[ -z "${RAW}" ]]; then
  printf 'HOST\tWWPN(port)\tWWNN(node)\tSTATE\tSPEED\tPCI\tDRIVER\tSYMBOLIC_NAME\n'
fi

# Iterate nodes and print their entries. If multiple nodes, keep results combined.
while IFS= read -r n; do
  [[ -z "$n" ]] && continue
  query_node "$n" "$RAW"
done <<< "$nodes"
